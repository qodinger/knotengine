{
  "name": "@knotengine/sdk",
  "author": "tyecode",
  "repository": {
    "type": "git",
    "url": "https://github.com/tyecode/knotengine.git"
  },
  "version": "0.2.0",
  "description": "Standard Node.js SDK for KnotEngine — The Non-Custodial Payment Gateway.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@knotengine/types": "workspace:*",
    "@types/node": "^25.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
