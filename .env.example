# ══════════════════════════════════════════════
# 🚀 KnotEngine — Environment Config
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Core Infrastructure ──
DATABASE_URL="mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/knotengine?retryWrites=true&w=majority"
REDIS_URL="redis://localhost:6379"

# ── Service Ports ──
PORT=5050
NEXT_PUBLIC_API_URL="http://localhost:5050"
NEXT_PUBLIC_CHECKOUT_URL="http://localhost:5051"
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:5052"

# ── Security & Secrets ──
# Shared secret for Dashboard <-> API communication
INTERNAL_SECRET="knot_internal_$(openssl rand -hex 16)"
# Core signing secrets
JWT_SECRET="change_me_in_production"
WEBHOOK_SECRET="change_me_in_production"

# ── Blockchain Configuration ──
BITCOIN_NETWORK="testnet"
PUBLIC_URL="https://your-public-api.com"

# Monitoring (Alchemy/Tatum)
ALCHEMY_API_KEY=""
ALCHEMY_WEBHOOK_SIGNING_KEY=""
TATUM_API_KEY=""
TATUM_WEBHOOK_SECRET=""
