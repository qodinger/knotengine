# ══════════════════════════════════════════════
# 🚀 TyePay (Knot Engine) — Environment Config
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ──
# MongoDB Atlas connection string.
# How to get:
#   1. Go to https://cloud.mongodb.com
#   2. Select your cluster → "Connect" → "Drivers"
#   3. Copy the connection string and replace <USERNAME>, <PASSWORD>, and <CLUSTER>
#   4. The database name "tyepay" is auto-created on first write
DATABASE_URL="mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/tyepay?retryWrites=true&w=majority"

# ── Redis (optional, for caching) ──
# Default works if running Redis locally or via Docker.
# How to get:
#   Option A: Run locally → pnpm docker:up (starts Redis on port 6379)
#   Option B: Use a cloud provider like Upstash (https://upstash.com) or Redis Cloud
REDIS_URL="redis://localhost:6379"

# ── App ──
# Node environment. Use "development" locally, "production" in prod.
NODE_ENV="development"

# Port configuration
PORT=5050
NEXT_PUBLIC_CHECKOUT_URL="http://localhost:5051"
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:5052"
NEXT_PUBLIC_API_URL="http://localhost:5050"
BITCOIN_NETWORK="bitcoin" # Use "testnet" for safe testing without real money

# Secret key for signing JWTs. Use a random 32+ character string in production.
# How to generate:
#   openssl rand -hex 32
JWT_SECRET="change_me_in_production"

# Secret key for signing outgoing webhook payloads (HMAC-SHA256).
# How to generate:
#   openssl rand -hex 32
WEBHOOK_SECRET="change_me_in_production"

# ── Alchemy (blockchain monitoring) ──
# Used for tracking on-chain transactions via webhooks.
# How to get:
#   1. Sign up at https://www.alchemy.com (free tier available)
#   2. Create an app → copy your API key
#   3. Go to "Notify" tab → create an Address Activity webhook
#   4. Copy the signing key from the webhook settings
ALCHEMY_API_KEY=""
TATUM_API_KEY="your_tatum_api_key_here"
PUBLIC_URL="https://your-public-api.com" # Required for automated webhook registration
ALCHEMY_WEBHOOK_SIGNING_KEY=""

# ── Tatum (alternative blockchain monitoring) ──
# Used for monitoring transactions on networks not covered by Alchemy.
# How to get:
#   1. Sign up at https://tatum.io
#   2. Create a notification/subscription
#   3. Get the HMAC secret for webhook signing
TATUM_WEBHOOK_SECRET=""
