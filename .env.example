# ══════════════════════════════════════════════
# 🚀 KnotEngine — Environment Config
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Core Infrastructure ──
DATABASE_URL="mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/knotengine?retryWrites=true&w=majority"
REDIS_URL="redis://localhost:6379"

# ── Service Ports ──
PORT=5050
NEXT_PUBLIC_API_URL="http://localhost:5050"
NEXT_PUBLIC_CHECKOUT_URL="http://localhost:5051"
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:5052"

# ── Security & Secrets ──
# Shared secret for Dashboard <-> API communication
INTERNAL_SECRET="knot_internal_$(openssl rand -hex 16)"
# Core signing secrets
JWT_SECRET="change_me_in_production"
WEBHOOK_SECRET="change_me_in_production"

# ── Blockchain Configuration ──
BITCOIN_NETWORK="testnet"
PUBLIC_URL="https://your-public-api.com"

# Monitoring Providers (Tatum + Redundancy)
TATUM_API_KEY=""
TATUM_WEBHOOK_SECRET=""

# Alchemy Backup (EVM Only)
# Get from: Alchemy Dash -> App -> Notify -> Auth Token
ALCHEMY_API_KEY=""
ALCHEMY_AUTH_TOKEN=""
ALCHEMY_NOTIFY_WEBHOOK_ID=""
ALCHEMY_WEBHOOK_SIGNING_KEY=""

# ── Business Logic ──
PLATFORM_FEE_RATE=0.01
PLATFORM_SPREAD_RATE=0.01
MIN_INVOICE_AMOUNT=1.00
MIN_FEE_USD=0.05
WELCOME_CREDIT_AMOUNT=5.00


# ── Platform Collection Wallets (For Billing/Credits) ──
# Receive merchant fee credits here (STABLECOINS ONLY: USDT/USDC)
PLATFORM_FEE_WALLET_EVM=0xe1426466316278A3317772E6F22BCcbca0565251

# ── Auth & Communication ──
RESEND_API_KEY="" # Get from https://resend.com
DASHBOARD_URL="http://localhost:5052"
# (Optional) Specific wallets for other networks if needed
# PLATFORM_FEE_WALLET_TRON=...

# ── Media Storage (Cloudinary) ──
# Get from: https://cloudinary.com -> Dashboard -> API Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
