{
  "name": "tyepay",
  "private": true,
  "description": "Minimalist, Non-Custodial Crypto Payment Infrastructure",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter api",
    "dev:checkout": "turbo run dev --filter checkout",
    "dev:dashboard": "turbo run dev --filter dashboard",
    "dev:full": "bash scripts/docker-up.sh && turbo run dev --filter api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "husky",
    "docker:up": "bash scripts/docker-up.sh",
    "docker:down": "bash scripts/docker-down.sh",
    "docker:status": "bash scripts/docker-status.sh",
    "docker:logs": "docker logs -f tyepay_mongo"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.0.0"
}
